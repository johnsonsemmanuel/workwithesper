# EsperWorks Invoice API (optional - set this to auto-create invoices)
ESPERWORKS_API_KEY=your-api-key-here

# Email (SMTP) - fallback if EsperWorks API not configured
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
NOTIFICATION_EMAIL=your-email@gmail.com

# Server
PORT=3000
